PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Banco de dados PostgreSQL (Supabase ou local)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@host:5432/banco
DB_SSL=true

# ─────────────────────────────────────────────
# RabbitMQ (MOM)
#
# Desenvolvimento local (backend fora do Docker):
#   RABBITMQ_URL=amqp://guest:guest@localhost:5672
#
# Docker Compose (backend dentro do container):
#   RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
#   (o docker-compose.yml já sobrescreve automaticamente)
# ─────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─────────────────────────────────────────────
# Segurança
# ─────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_forte_e_aleatoria
ADMIN_API_KEY=troque_por_uma_chave_admin_segura

# ─────────────────────────────────────────────
# Configurações de senha (PBKDF2)
# ─────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
PBKDF2_ITERATIONS=120000
PBKDF2_KEY_LENGTH=64
PBKDF2_DIGEST=sha512
