    {
      "name": "Tickets (Sprint 2 - MOM)",
      "description": "Fluxo completo de chamados. Cada requisicao bem-sucedida publica um evento no RabbitMQ (ticket.created ou ticket.status_changed). Observe os logs do backend para ver os eventos sendo publicados e consumidos de forma assincrona.",
      "item": [
        {
          "name": "POST /tickets - cliente abre chamado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Ticket criado com status pending', function () {",
                  "  var data = pm.response.json();",
                  "  pm.expect(data.success).to.eql(true);",
                  "  pm.expect(data.data).to.have.property('id');",
                  "  pm.expect(data.data.status).to.eql('pending');",
                  "  pm.expect(data.data.specialty).to.eql('Eletrica');",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data.data && data.data.id) {",
                  "  pm.collectionVariables.set('ticketId', data.data.id);",
                  "}",
                  "",
                  "pm.test('ticketId salvo na variavel', function () {",
                  "  pm.expect(pm.collectionVariables.get('ticketId')).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('[MOM] Evento ticket.created publicado (verificar log do backend)', function () {",
                  "  pm.expect(true).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{customerToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specialty\": \"Eletrica\",\n  \"title\": \"Tomada com fagulha na sala\",\n  \"description\": \"A tomada da sala esta faiscando ao ligar qualquer aparelho.\",\n  \"addressText\": \"Rua das Flores, 123 - Belo Horizonte/MG\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"]
            }
          }
        },
        {
          "name": "GET /tickets - cliente lista seus chamados",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Retorna lista de chamados do cliente', function () {",
                  "  var data = pm.response.json();",
                  "  pm.expect(data.success).to.eql(true);",
                  "  pm.expect(data.data).to.be.an('array');",
                  "  pm.expect(data.total).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Chamado criado aparece na lista', function () {",
                  "  var data = pm.response.json();",
                  "  var ticketId = pm.collectionVariables.get('ticketId');",
                  "  var found = data.data.some(function(t) { return t.id === ticketId; });",
                  "  pm.expect(found).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{customerToken}}"}],
