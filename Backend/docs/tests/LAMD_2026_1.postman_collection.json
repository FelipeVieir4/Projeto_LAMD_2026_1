  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "(function () {",
          "  var isInitialized = pm.collectionVariables.get('runInitialized') === 'true';",
          "  var baseUrl = pm.collectionVariables.get('baseUrl') || 'http://localhost:3000';",
          "  var defaultPassword = pm.collectionVariables.get('defaultPassword') || 'SenhaForte123';",
          "  var adminApiKey = pm.collectionVariables.get('adminApiKey') || 'troque_esta_chave_admin';",
          "",
          "  pm.collectionVariables.set('baseUrl', baseUrl);",
          "  pm.collectionVariables.set('defaultPassword', defaultPassword);",
          "  pm.collectionVariables.set('adminApiKey', adminApiKey);",
          "",
          "  if (!isInitialized) {",
          "    var runId = Date.now().toString();",
          "    pm.collectionVariables.set('runId', runId);",
          "    pm.collectionVariables.set('customerEmail', 'cliente.' + runId + '@lamd.local');",
          "    pm.collectionVariables.set('partnerEmail', 'parceiro.' + runId + '@lamd.local');",
          "    pm.collectionVariables.set('customerToken', '');",
          "    pm.collectionVariables.set('partnerToken', '');",
          "    pm.collectionVariables.set('specialtyId', '');",
          "    pm.collectionVariables.set('ticketId', '');",
          "    pm.collectionVariables.set('runInitialized', 'true');",
          "  }",
          "})();"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has status, database and timestamp', function () {",
                  "  var data = pm.response.json();",
                  "  pm.expect(data).to.have.property('status');",
                  "  pm.expect(data).to.have.property('database');",
                  "  pm.expect(['ok', 'unavailable']).to.include(data.database);",
                  "  pm.expect(data).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
