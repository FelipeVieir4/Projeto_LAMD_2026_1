      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var partnerToken = pm.collectionVariables.get(\"partnerToken\");",
              "if (partnerToken && partnerToken.length > 20) return;",
              "",
              "var baseUrl  = pm.collectionVariables.get(\"baseUrl\") || \"http://localhost:3000/api/v1\";",
              "var password = pm.collectionVariables.get(\"defaultPassword\") || \"SenhaForte123\";",
              "var pEmail   = \"auto.parceiro.\" + Date.now() + \"@lamd.local\";",
              "pm.collectionVariables.set(\"partnerEmail\", pEmail);",
              "",
              "pm.sendRequest({",
              "  url: baseUrl + \"/auth/register\",",
              "  method: \"POST\",",
              "  header: { \"Content-Type\": \"application/json\" },",
              "  body: {",
              "    mode: \"raw\",",
              "    raw: JSON.stringify({",
              "      program: \"partner\",",
              "      companyName: \"Admin Auto LTDA\",",
              "      document: \"99.888.777/0001-66\",",
              "      email: pEmail,",
              "      password: password,",
              "      specialties: [\"eletrica\"]",
              "    })",
              "  }",
              "}, function (err, res) {",
              "  var d = res.json();",
              "  if (d && d.token) pm.collectionVariables.set(\"partnerToken\", d.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Tickets (Sprint 2 - MOM)",
      "description": "Fluxo completo de chamados com eventos RabbitMQ. O pre-request desta pasta garante que os tokens existam — registra e faz login automaticamente se necessario. Observe o terminal do backend para ver os pares [PUBLISH] e [CONSUME] em tempo real.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Auto-setup: registra cliente e parceiro se os tokens estiverem ausentes",
              "var customerToken = pm.collectionVariables.get('customerToken');",
              "var partnerToken  = pm.collectionVariables.get('partnerToken');",
              "",
              "if (customerToken && customerToken.length > 20 &&",
              "    partnerToken  && partnerToken.length  > 20) {",
              "  return; // tokens validos, nao precisa fazer nada",
              "}",
              "",
              "var baseUrl  = pm.collectionVariables.get('baseUrl')  || 'http://localhost:3000/api/v1';",
              "var password = pm.collectionVariables.get('defaultPassword') || 'SenhaForte123';",
              "var ts       = Date.now().toString();",
              "var cEmail   = 'auto.cliente.'  + ts + '@lamd.local';",
              "var pEmail   = 'auto.parceiro.' + ts + '@lamd.local';",
              "",
              "pm.collectionVariables.set('customerEmail', cEmail);",
              "pm.collectionVariables.set('partnerEmail',  pEmail);",
              "",
              "// Registra cliente e salva token",
              "pm.sendRequest({",
              "  url: baseUrl + '/auth/register',",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/json' },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({",
              "      program: 'customer',",
              "      name: 'Cliente Auto',",
              "      email: cEmail,",
              "      password: password",
              "    })",
              "  }",
              "}, function (err, res) {",
              "  var d = res.json();",
              "  if (d && d.token) pm.collectionVariables.set('customerToken', d.token);",
              "});",
              "",
              "// Registra parceiro e salva token",
              "pm.sendRequest({",
              "  url: baseUrl + '/auth/register',",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/json' },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({",
              "      program: 'partner',",
              "      companyName: 'Parceiro Auto LTDA',",
              "      document: '99.999.999/0001-99',",
              "      email: pEmail,",
              "      password: password,",
              "      specialties: ['eletrica']",
              "    })",
              "  }",
              "}, function (err, res) {",
              "  var d = res.json();",
              "  if (d && d.token) pm.collectionVariables.set('partnerToken', d.token);",
              "});"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "POST /tickets - cliente abre chamado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Chamado criado com status pending e ticketId salvo', () => {",
                  "  var d = pm.response.json();",
                  "  pm.expect(d.success).to.eql(true);",
                  "  pm.expect(d.data.status).to.eql('pending');",
                  "  pm.expect(d.data.id).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('ticketId', d.data.id);",
                  "});",
                  "pm.test('[MOM] Verificar no terminal do backend: [PUBLISH] ticket.created + [CONSUME] ticket.created', () => pm.expect(true).to.eql(true));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
